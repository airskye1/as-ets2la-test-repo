<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ETS2LA.UI.Views.Settings"
             xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
             x:Class="ETS2LA.UI.Views.Settings.AssistanceSettingsPage"
             x:DataType="views:AssistanceSettingsPage">
    <StackPanel>
        <Grid ColumnDefinitions="450,*">
        <StackPanel Grid.Column="0" Spacing="20" Margin="20">

            <!--
            <StackPanel Spacing="10" Tapped="OnSeparateCruiseAndSteeringClicked">
                <StackPanel Spacing="3">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <husk:Tag IsVisible="{Binding SeparateCruiseAndSteering}" Classes="Primary" Width="35">
                            <TextBlock Text="ON " Classes="Highlight" HorizontalAlignment="Center" />
                        </husk:Tag>
                        <husk:Tag IsVisible="{Binding !SeparateCruiseAndSteering}" Classes="Secondary" Width="35">
                            <TextBlock Text="OFF" Classes="Description" HorizontalAlignment="Center" />
                        </husk:Tag>
                        <TextBlock Text="Separate Cruise and Steering" />
                    </StackPanel>
                    <TextBlock Text="Whether to separate cruise control and steering. If separated, a single tap will signal Cruise, while a double tap will enable both." FontSize="12" Classes="Description" />
                </StackPanel>
            </StackPanel>
            -->

            <StackPanel Spacing="10">
                <StackPanel Spacing="3">
                    <TextBlock Text="SET Behaviour" />
                    <TextBlock Text="When pressing the SET button, what should ETS2LA set as the current cruise control speed?" FontSize="12" Classes="Description" />
                </StackPanel>
                <TabStrip ItemsSource="{Binding SetSpeedBehaviourOptions}" 
                        SelectedIndex="{Binding SelectedSetSpeedBehaviourOption}" 
                        SelectionChanged="OnSetSpeedBehaviourChanged"
                        AutomationProperties.Name="SET Keybind Behaviour">

                    <TabStrip.Styles>
                        <Style Selector="TabStripItem" x:DataType="views:TabStripItemHandler">
                            <Setter Property="AutomationProperties.Name" Value="{Binding AutomationName}" />
                        </Style>
                    </TabStrip.Styles>

                    <TabStrip.ItemTemplate>
                        <DataTemplate x:DataType="views:TabStripItemHandler">
                            <Border Width="115" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center" AutomationProperties.Name="{Binding AutomationName}">
                                <TextBlock Text="{Binding Header}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </TabStrip.ItemTemplate>
                </TabStrip>
            </StackPanel>

            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="{Binding SnapTo10UnitsDisplay}" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding SnapTo10Units}" Classes="primary-toggle" AutomationProperties.Name="Snap ACC to 10 units" />
                </Grid>
                <TextBlock Text="When changing the speed, snap to the nearest 10 units. i.e. 37 -> 39 -> 40 -> 42..." FontSize="12" Classes="Description" />
            </StackPanel>

            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Speed Control Step Size" />
                    <TextBlock Text="{Binding SpeedControlDisplay}" />
                </StackPanel>
                <Slider Name="SpeedControlStepSizeSlider" Minimum="1" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding SpeedControlStepSize}" AutomationProperties.Name="ACC speed control step size" />
            </StackPanel>

            <Separator />

            <StackPanel Spacing="10">
                <StackPanel Spacing="3">
                    <TextBlock Text="Steering Response" />
                    <TextBlock Text="Adjust how ETS2LA will respond to necessary steering changes. This for example controls how quickly ETS2LA will lane-change." FontSize="12" Classes="Description" />
                </StackPanel>
                <TabStrip ItemsSource="{Binding SteeringSensitivityOptions}" 
                        SelectedIndex="{Binding SelectedSteeringSensitivityOption}" 
                        SelectionChanged="OnSteeringSensitivityChanged"
                        AutomationProperties.Name="Steering response">

                    <TabStrip.Styles>
                        <Style Selector="TabStripItem" x:DataType="views:TabStripItemHandler">
                            <Setter Property="AutomationProperties.Name" Value="{Binding AutomationName}" />
                        </Style>
                    </TabStrip.Styles>

                    <TabStrip.ItemTemplate>
                        <DataTemplate x:DataType="views:TabStripItemHandler">
                            <Border Width="70" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center" AutomationProperties.Name="{Binding AutomationName}">
                                <TextBlock Text="{Binding Header}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </TabStrip.ItemTemplate>
                </TabStrip>
            </StackPanel>
            
            <StackPanel Spacing="10">
                <StackPanel Spacing="3">
                    <TextBlock Text="Acceleration Response" />
                    <TextBlock Text="Adjust how quickly ETS2LA will respond to desired changes in acceleration. Emergency braking is not affected." FontSize="12" Classes="Description" />
                </StackPanel>
                <TabStrip ItemsSource="{Binding AccelerationOptions}" 
                        SelectedIndex="{Binding SelectedAccelerationOption}"
                        SelectionChanged="OnAccelerationOptionChanged"
                        AutomationProperties.Name="Acceleration response">

                    <TabStrip.Styles>
                        <Style Selector="TabStripItem" x:DataType="views:TabStripItemHandler">
                            <Setter Property="AutomationProperties.Name" Value="{Binding AutomationName}" />
                        </Style>
                    </TabStrip.Styles>

                    <TabStrip.ItemTemplate>
                        <DataTemplate x:DataType="views:TabStripItemHandler">
                            <Border Width="70" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center" AutomationProperties.Name="{Binding AutomationName}">
                                <TextBlock Text="{Binding Header}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </TabStrip.ItemTemplate>
                </TabStrip>
            </StackPanel>

            <StackPanel Spacing="10">
                <StackPanel Spacing="3">
                    <TextBlock Text="Following Distance" />
                    <TextBlock Text="Adjust the distance ETS2LA will try to maintain from the vehicle in front of you when using adaptive cruise control." FontSize="12" Classes="Description" />
                </StackPanel>
                <TabStrip ItemsSource="{Binding FollowingDistanceOptions}" 
                        SelectedIndex="{Binding SelectedFollowingDistanceOption}" 
                        SelectionChanged="OnFollowingDistanceChanged"
                        AutomationProperties.Name="Following distance">

                    <TabStrip.Styles>
                        <Style Selector="TabStripItem" x:DataType="views:TabStripItemHandler">
                            <Setter Property="AutomationProperties.Name" Value="{Binding AutomationName}" />
                        </Style>
                    </TabStrip.Styles>

                    <TabStrip.ItemTemplate>
                        <DataTemplate x:DataType="views:TabStripItemHandler">
                            <Border Width="70" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center" AutomationProperties.Name="{Binding AutomationName}">
                                <TextBlock Text="{Binding Header}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </TabStrip.ItemTemplate>
                </TabStrip>
            </StackPanel>

            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="Ignore Traffic Rules" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding IgnoreTrafficRules}" Classes="primary-toggle" AutomationProperties.Name="Ignore Traffic Rules" />
                </Grid>
                <TextBlock Text="We will ignore traffic rules and speed limits. Expect damage to your vehicle and others. Why would you enable this?" FontSize="12" Classes="Description" />
            </StackPanel>

            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Maximum Speed" />
                    <TextBlock Text="{Binding MaximumSpeedDisplay}" />
                </StackPanel>
                <Slider Name="MaximumSpeedSlider" Minimum="0" Maximum="120" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding MaximumSpeed}" AutomationProperties.Name="Maximum speed limit" />
            </StackPanel>

            <Separator />

            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="Pause When Unstable" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding PauseWhenUnstable}" Classes="primary-toggle" AutomationProperties.Name="Pause When Unstable" />
                </Grid>
                <TextBlock Text="We will pause the game when we detect instability or the steering is unresponsive / disables itself." FontSize="12" Classes="Description" />
            </StackPanel>

            <StackPanel Spacing="10">
                <StackPanel Spacing="3">
                    <TextBlock Text="Speed Limit Warning" />
                    <TextBlock Text="How should ETS2LA warn you about speed limits?" FontSize="12" Classes="Description" />
                </StackPanel>
                <TabStrip ItemsSource="{Binding SpeedLimitWarningOptions}" 
                        SelectedIndex="{Binding SelectedSpeedLimitWarningOption}"
                        SelectionChanged="OnSpeedLimitWarningChanged"
                        AutomationProperties.Name="Speedlimit warning style">

                    <TabStrip.Styles>
                        <Style Selector="TabStripItem" x:DataType="views:TabStripItemHandler">
                            <Setter Property="AutomationProperties.Name" Value="{Binding AutomationName}" />
                        </Style>
                    </TabStrip.Styles>

                    <TabStrip.ItemTemplate>
                        <DataTemplate x:DataType="views:TabStripItemHandler">
                            <Border Width="70" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center" AutomationProperties.Name="{Binding AutomationName}">
                                <TextBlock Text="{Binding Header}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </TabStrip.ItemTemplate>
                </TabStrip>
            </StackPanel>

            <StackPanel Spacing="10">
                <StackPanel Spacing="3">
                    <TextBlock Text="Collision Avoidance" />
                    <TextBlock Text="At what time should ETS2LA intervene to avoid a collision?" FontSize="12" Classes="Description" />
                </StackPanel>
                <TabStrip ItemsSource="{Binding CollisionAvoidanceOptions}" 
                        SelectedIndex="{Binding SelectedCollisionAvoidanceOption}" 
                        SelectionChanged="OnCollisionAvoidanceChanged"
                        AutomationProperties.Name="Collision avoidance distance">

                    <TabStrip.Styles>
                        <Style Selector="TabStripItem" x:DataType="views:TabStripItemHandler">
                            <Setter Property="AutomationProperties.Name" Value="{Binding AutomationName}" />
                        </Style>
                    </TabStrip.Styles>

                    <TabStrip.ItemTemplate>
                        <DataTemplate x:DataType="views:TabStripItemHandler">
                            <Border Width="70" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center" AutomationProperties.Name="{Binding AutomationName}">
                                <TextBlock Text="{Binding Header}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </TabStrip.ItemTemplate>
                </TabStrip>
            </StackPanel>
        </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>