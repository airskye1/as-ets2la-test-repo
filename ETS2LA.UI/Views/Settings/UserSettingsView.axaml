<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ETS2LA.UI.Views.Settings"
             x:Class="ETS2LA.UI.Views.Settings.UserSettingsView"
             x:DataType="views:UserSettingsView">
    <Grid ColumnDefinitions="450,*">
        <StackPanel Grid.Column="0" Spacing="20" Margin="20">
        
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="Enable Anonymous Telemetry" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsTelemetryEnabled}" Classes="primary-toggle" AutomationProperties.Name="Enable Anonymous Telemetry, needs restart" />
                </Grid>
                <TextBlock Text="Anonymous telemetry helps us improve ETS2LA by giving us insights into users' system specs, crashes, and other usage data. Your data cannot be identified with any personal information." FontSize="12" Classes="Description" />
            </StackPanel>

            <StackPanel Spacing="12" IsVisible="{Binding NeedsRestart}">
                <TextBlock Text="This value requires a restart to take effect." FontSize="12" Classes="Warning" />
            </StackPanel>

            <StackPanel Spacing="12">
                <HyperlinkButton Content="View Public Telemetry Data" NavigateUri="https://telemetry.ets2la.com/public-dashboards/17f53fce4749475c8efcab181b1306f3" FontSize="12" AutomationProperties.Name="View Public Telemetry" />
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>