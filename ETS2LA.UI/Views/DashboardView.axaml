<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ETS2LA.UI.Views"
             xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             x:Class="ETS2LA.UI.Views.DashboardView"
             x:DataType="views:DashboardView">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="14">
            <!-- If someone can tell me how to do this without MaxWidth then please do so... -->
            <UniformGrid Columns="2" ColumnSpacing="14"
                MaxWidth="{Binding Extent.Width, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                <husk:Card Padding="16">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock FontSize="18" FontFamily="{StaticResource Geist}">
                                Welcome back, <Span Classes="Highlight">Anonymous</Span>!
                            </TextBlock>
                        </Grid>

                        <WrapPanel ItemSpacing="16">
                            <StackPanel Spacing="4">
                                <husk:Tag>
                                    <TextBlock Text="Current Release" FontSize="12" />
                                </husk:Tag>
                                <TextBlock Text="{Binding CurrentRelease}" FontSize="13" Margin="6 0 0 0"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <husk:Tag>
                                    <TextBlock Text="Users Online" FontSize="12" />
                                </husk:Tag>
                                <TextBlock Text="-" FontSize="13" Margin="6 0 0 0"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <husk:Tag>
                                    <TextBlock Text="Users Over 24h" FontSize="12" />
                                </husk:Tag>
                                <TextBlock Text="-" FontSize="13" Margin="6 0 0 0"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </husk:Card>
            </UniformGrid>

            <UniformGrid Columns="2" ColumnSpacing="14"
                MaxWidth="{Binding Extent.Width, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                <husk:Card Padding="16">
                    <Grid RowDefinitions="Auto,*" RowSpacing="16">
                        <StackPanel Grid.Row="0" Spacing="4" VerticalAlignment="Top">
                            <TextBlock Text="Support &amp; Updates" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock HorizontalAlignment="Stretch" Text="Follow development and get support. Keep in mind that this version of ETS2LA is still in development. If you find bugs, please report them!" Classes="Description" FontSize="13"/>
                        </StackPanel>
                        <WrapPanel Grid.Row="1" ItemSpacing="8" VerticalAlignment="Bottom">
                            <Button Content="Documentation" Click="OpenDocumentation" AutomationProperties.Name="Open the ETS2LA Documentation in Browser, button"/>
                            <Button Content="GitHub" Click="OpenGitHub" AutomationProperties.Name="Open the ETS2LA GitHub in Browser, button"/>
                            <Button Content="Discord" Click="OpenDiscord" AutomationProperties.Name="Open the ETS2LA Discord in Browser, button"/>
                        </WrapPanel>
                    </Grid>
                </husk:Card>
            </UniformGrid>

            <UniformGrid Columns="2" ColumnSpacing="14"
                MaxWidth="{Binding Extent.Width, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                <husk:Card Padding="16">
                    <Grid RowDefinitions="Auto,*" RowSpacing="16">
                        <StackPanel Grid.Row="0" Spacing="4" VerticalAlignment="Top">
                            <TextBlock Text="Sponsor Us" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock HorizontalAlignment="Stretch" Text="Your supports helps me continue developing ETS2LA! The more donations we get the more time I can dedicate to improving the project. Thank you!" Classes="Description" FontSize="13"/>
                        </StackPanel>
                        <WrapPanel Grid.Row="1" ItemSpacing="8" VerticalAlignment="Bottom">
                            <Button Content="Donate to Development" Click="OpenDonate" Classes="Primary" AutomationProperties.Name="Open Tumppi066's Donation Page in Browser, button"/>
                        </WrapPanel>
                    </Grid>
                </husk:Card>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
